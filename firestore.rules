
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- وظائف مساعدة للتحقق (Security Helpers) ---
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }

    // التحقق من صلاحيات المدير العام (Super Admin فقط)
    function isSuperAdmin() {
      return isAuthenticated() && getUserData(request.auth.uid).role == "Super Admin";
    }

    // التحقق من صلاحيات الطاقم الإداري (إدارة العمليات اليومية)
    function isAdmin() {
      return isAuthenticated() && 
        getUserData(request.auth.uid).role in ["Super Admin", "Manager", "Financial Officer", "Customer Service"];
    }

    // التحقق من ملكية المستند
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // التحقق من أن الحساب ليس محظوراً
    function isActive() {
      return isAuthenticated() && getUserData(request.auth.uid).status == "Active";
    }

    // التحقق من الحقول المسموح للمستخدم العادي تعديلها في ملفه الشخصي
    function isOwnerUpdatingAllowedFields() {
      let allowedFields = ["name", "phone", "wilaya", "commune", "avatarUrl", "location"];
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowedFields);
    }

    // --- 1. مجموعة المستخدمين (Users) ---
    match /users/{userId} {
      allow read: if isAdmin() || isOwner(userId);
      
      // الإنشاء مسموح للمستخدم لنفسه (مع فرض دور Customer افتراضياً إذا لم يكن أدمن)
      allow create: if isAuthenticated() && request.auth.uid == userId;
      
      allow update: if isSuperAdmin() 
                   || (isAdmin() && userId != request.auth.uid) // الأدمن يعدل الآخرين ولا يعدل نفسه (لتجنب تغيير رتبته)
                   || (isOwner(userId) && isOwnerUpdatingAllowedFields()); // المالك يعدل بياناته المحدودة فقط
      
      // الحذف حصري للمدير العام
      allow delete: if isSuperAdmin();
    }

    // --- 2. المنتجات والإعلانات (Products & Listings) ---
    match /{collectionName}/{docId} {
      allow read: if collectionName in ["listings", "products"];
      
      allow create: if collectionName in ["listings", "products"] 
                   && isAuthenticated() 
                   && isActive()
                   && (request.resource.data.sellerId == request.auth.uid);
                   
      allow update, delete: if collectionName in ["listings", "products"] 
                           && (isAdmin() || (resource.data.sellerId == request.auth.uid));
    }

    // --- 3. طلبات الشراء (Purchase Requests & Orders) ---
    match /{collectionName}/{docId} {
      allow read: if collectionName in ["purchase_requests", "orders"]
                   && (isAdmin() || (isAuthenticated() && (resource.data.buyerId == request.auth.uid || resource.data.sellerId == request.auth.uid)));
      
      allow create: if collectionName in ["purchase_requests", "orders"]
                   && isAuthenticated()
                   && isActive()
                   && (request.resource.data.buyerId == request.auth.uid);
                   
      allow update: if collectionName in ["purchase_requests", "orders"]
                   && (isAdmin() || (isAuthenticated() && resource.data.sellerId == request.auth.uid));

      allow delete: if isSuperAdmin();
    }

    // --- 4. العمليات المالية (Payments) ---
    match /payments/{paymentId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && isActive() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // --- 5. الشكاوى والبلاغات (Complaints) ---
    match /complaints/{complaintId} {
      allow create: if isAuthenticated() && isActive();
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    // --- 6. الاشتراكات والخطط (Subscriptions & Plans) ---
    match /subscriptions/{subId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.sellerId == request.auth.uid);
      allow write: if isAdmin();
    }
    
    match /plans/{planId} {
      allow read: if true;
      allow write: if isSuperAdmin(); // تغيير أسعار الباقات حصري للمدير العام
    }

    // --- 7. المحتوى التسويقي والإعدادات (Banners & Settings) ---
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /settings/{settingId} {
      allow read: if true; // القراءة عامة لعرض هوية الموقع
      allow write: if isSuperAdmin(); // التعديل حصري للمدير العام
    }

    // --- 8. سجل الرقابة والعمليات (Audit Logs) ---
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false; // لا يمكن لأي شخص الكتابة مباشرة في السجل، يتم عبر Cloud Functions أو النظام فقط
    }
  }
}

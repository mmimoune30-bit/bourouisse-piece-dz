
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ["SuperAdmin", "Manager", "FinancialOfficer", "CustomerService"]);
    }

    // Listings: Anyone can read, only sellers can create
    match /listings/{listingId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && (request.auth.uid == resource.data.sellerId || isAdmin());
    }

    // Sellers: Anyone can read, only owner or admin can update
    match /sellers/{sellerId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
    }

    // Complaints: Owner or admin
    match /complaints/{complaintId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
    }

    // Purchase Requests: Buyer, Seller or Admin
    match /purchase_requests/{requestId} {
      allow create: if true; // Allow visitors to make a request
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.buyerId || request.auth.uid == resource.data.sellerId || isAdmin());
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.sellerId || isAdmin());
      allow delete: if isAdmin();
    }

    // Payments: Admin only, or owner read
    match /payments/{paymentId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow update, delete: if isAdmin();
    }
    
    // User profile roles
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
    }
  }
}

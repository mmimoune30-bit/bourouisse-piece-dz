
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- وظائف مساعدة للتحقق (Security Helpers) ---
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }

    // التحقق من صلاحيات المدير العام (Super Admin فقط)
    function isSuperAdmin() {
      return isAuthenticated() && (
        getUserData(request.auth.uid).role == "Super Admin" || 
        request.auth.token.email == "mmimoune30@gmail.com"
      );
    }

    // التحقق من صلاحيات الطاقم الإداري
    function isAdmin() {
      return isAuthenticated() && 
        getUserData(request.auth.uid).role in ["Super Admin", "Manager", "Financial Officer", "Customer Service"];
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isActive() {
      return isAuthenticated() && getUserData(request.auth.uid).status == "Active";
    }

    // التحقق من أن المستخدم لا يمنح نفسه صلاحيات أدمن عند الإنشاء
    function isValidInitialRole() {
      let role = request.resource.data.role;
      return role in ["Customer", "Seller"] || request.auth.token.email == "mmimoune30@gmail.com";
    }

    function isOwnerUpdatingAllowedFields() {
      let allowedFields = ["name", "phone", "wilaya", "commune", "avatarUrl", "location"];
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowedFields);
    }

    // --- 1. مجموعة المستخدمين (Users) ---
    match /users/{userId} {
      allow read: if isAdmin() || isOwner(userId);
      
      // منع إنشاء حساب أدمن إلا للبريد المخصص
      allow create: if isAuthenticated() 
                   && request.auth.uid == userId 
                   && isValidInitialRole();
      
      allow update: if isSuperAdmin() 
                   || (isAdmin() && userId != request.auth.uid)
                   || (isOwner(userId) && isOwnerUpdatingAllowedFields());
      
      allow delete: if isSuperAdmin();
    }

    // --- 2. المنتجات والإعلانات (Products & Listings) ---
    match /{collectionName}/{docId} {
      allow read: if collectionName in ["listings", "products"];
      
      allow create: if collectionName in ["listings", "products"] 
                   && isAuthenticated() 
                   && isActive()
                   && (request.resource.data.sellerId == request.auth.uid);
                   
      allow update: if collectionName in ["listings", "products"] 
                           && (isAdmin() || (resource.data.sellerId == request.auth.uid));

      allow delete: if isAdmin() || (isAuthenticated() && resource.data.sellerId == request.auth.uid);
    }

    // --- 3. طلبات الشراء (Purchase Requests) ---
    match /purchase_requests/{reqId} {
      allow read: if isAdmin() || (isAuthenticated() && (resource.data.buyerId == request.auth.uid || resource.data.sellerId == request.auth.uid));
      allow create: if isAuthenticated() && isActive() && request.resource.data.buyerId == request.auth.uid;
      allow update: if isAdmin() || (isAuthenticated() && resource.data.sellerId == request.auth.uid);
      allow delete: if isSuperAdmin();
    }

    // --- 4. العمليات المالية (Payments) ---
    match /payments/{paymentId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && isActive() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // --- 5. الشكاوى والبلاغات (Complaints) ---
    match /complaints/{complaintId} {
      allow create: if isAuthenticated() && isActive();
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    // --- 6. الإعدادات والبنرات ---
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}


rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- وظائف مساعدة للتحقق (Security Helpers) ---
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData(uid) {
      // جلب بيانات المستخدم من Firestore للتحقق من الدور
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }

    // التحقق من صلاحيات المدير (Super Admin, Manager, Financial Officer, Customer Service)
    function isAdmin() {
      return isAuthenticated() && 
        getUserData(request.auth.uid).role in ["Super Admin", "Manager", "Financial Officer", "Customer Service"];
    }

    // التحقق من ملكية المستند
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // التحقق من أن الحساب ليس محظوراً (Active)
    function isActive() {
      return isAuthenticated() && getUserData(request.auth.uid).status == "Active";
    }

    // --- 1. مجموعة المستخدمين (Users) ---
    match /users/{userId} {
      // حماية البيانات الشخصية: القراءة فقط للمالك أو الأدمن
      allow read: if isAdmin() || isOwner(userId);
      // الإنشاء مسموح فقط للمستخدم المصادق عليه لنفسه
      allow create: if isAuthenticated() && request.auth.uid == userId;
      // التحديث للمالك (بيانات محدودة) أو الأدمن
      allow update: if isAdmin() || isOwner(userId);
      // الحذف للأدمن فقط
      allow delete: if isAdmin();
    }

    // --- 2. المنتجات والإعلانات (Products & Listings) ---
    // قراءة عامة للجميع، كتابة للمالك (البائع) أو الأدمن
    match /{collectionName}/{docId} {
      allow read: if collectionName in ["listings", "products"];
      
      allow create: if collectionName in ["listings", "products"] 
                   && isAuthenticated() 
                   && isActive()
                   && (isAdmin() || (request.resource.data.sellerId == request.auth.uid));
                   
      allow update, delete: if collectionName in ["listings", "products"] 
                           && (isAdmin() || (resource.data.sellerId == request.auth.uid));
    }

    // --- 3. طلبات الشراء (Purchase Requests & Orders) ---
    match /{collectionName}/{docId} {
      allow read: if collectionName in ["purchase_requests", "orders"]
                   && (isAdmin() || (isAuthenticated() && (resource.data.buyerId == request.auth.uid || resource.data.sellerId == request.auth.uid)));
      
      allow create: if collectionName in ["purchase_requests", "orders"]
                   && isAuthenticated()
                   && isActive()
                   && (request.resource.data.buyerId == request.auth.uid);
                   
      allow update: if collectionName in ["purchase_requests", "orders"]
                   && (isAdmin() || (isAuthenticated() && resource.data.sellerId == request.auth.uid));

      allow delete: if isAdmin();
    }

    // --- 4. العمليات المالية (Payments) ---
    match /payments/{paymentId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && isActive() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // --- 5. الشكاوى والبلاغات (Complaints) ---
    match /complaints/{complaintId} {
      allow create: if isAuthenticated() && isActive();
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    // --- 6. الاشتراكات والخطط (Subscriptions & Plans) ---
    match /subscriptions/{subId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.sellerId == request.auth.uid);
      allow write: if isAdmin();
    }
    
    match /plans/{planId} {
      allow read: if true; // جداول الأسعار عامة للمقارنة
      allow write: if isAdmin();
    }

    // --- 7. المحتوى التسويقي والإعدادات (Banners & Settings) ---
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- 8. سجل الرقابة والعمليات (Audit Logs) ---
    match /audit_logs/{logId} {
      allow read, write: if isAdmin();
    }
  }
}

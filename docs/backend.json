
{
  "entities": {
    "Listing": {
      "title": "إعلان قطعة غيار أو مركبة",
      "description": "بيانات تفصيلية لقطعة غيار أو مركبة معروضة للبيع",
      "type": "object",
      "properties": {
        "listingType": { 
          "type": "string", 
          "enum": ["part", "vhs", "accidented", "for_parts"],
          "description": "نوع الإعلان: قطعة منفردة، مركبة خارج الخدمة، مركبة مصدومة، مركبة للقطع"
        },
        "category": { "type": "string", "description": "الفئة الرئيسية (مثال: محرك، مركبات خارج الخدمة)" },
        "partType": { "type": "string", "description": "نوع القطعة أو نوع المركبة" },
        "manualPartName": { "type": "string", "description": "اسم القطعة المدخل يدوياً" },
        "brand": { "type": "string", "description": "العلامة التجارية للمركبة" },
        "model": { "type": "string", "description": "موديل المركبة" },
        "year": { "type": "string", "description": "سنة الصنع" },
        "motorisation": { "type": "string", "description": "نوع المحرك" },
        "fuelType": { "type": "string", "enum": ["Essence", "Diesel", "GPL", "Hybride", "Électrique"] },
        "gearbox": { "type": "string", "enum": ["Manuelle", "Automatique"] },
        "mileage": { "type": "number", "description": "المسافة المقطوعة بالكيلومتر" },
        "vehicleStatus": { 
          "type": "array", 
          "items": { "type": "string" },
          "description": "حالة المركبة (مصدومة، عطل محرك، إلخ)" 
        },
        "paperStatus": { "type": "string", "enum": ["Sans papiers", "Avec papiers"] },
        "availableParts": { 
          "type": "array", 
          "items": { "type": "string" },
          "description": "القطع المتاحة في المركبة" 
        },
        "condition": { "type": "string", "enum": ["new", "used", "damaged"], "description": "حالة القطعة أو المركبة" },
        "damagePercentage": { "type": "number", "description": "نسبة التحطم (0-100)" },
        "price": { "type": "number", "description": "السعر بالدينار الجزائري" },
        "priceNegotiable": { "type": "boolean", "description": "السعر قابل للتفاوض" },
        "wilaya": { "type": "string", "description": "ولاية البائع" },
        "commune": { "type": "string", "description": "بلدية البائع" },
        "description": { "type": "string", "description": "وصف إضافي" },
        "images": { "type": "array", "items": { "type": "string" }, "description": "روابط صور القطعة" },
        "phone": { "type": "string", "description": "رقم الهاتف للتواصل" },
        "sellerId": { "type": "string", "description": "معرف البائع صاحب الإعلان" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["listingType", "brand", "model", "price", "wilaya"]
    },
    "Seller": {
      "title": "بائع",
      "description": "بيانات حساب التاجر أو البائع",
      "type": "object",
      "properties": {
        "shopName": { "type": "string", "description": "اسم المتجر" },
        "phone": { "type": "string", "description": "رقم الهاتف" },
        "wilaya": { "type": "string", "description": "مقر النشاط" },
        "email": { "type": "string", "format": "email" },
        "userId": { "type": "string", "description": "معرف المستخدم المرتبط" }
      }
    },
    "Buyer": {
      "title": "مشتري",
      "description": "بيانات حساب المشتري",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "userId": { "type": "string" }
      }
    },
    "Payment": {
      "title": "عملية دفع",
      "description": "بيانات عملية الدفع مقابل اشتراك أو خدمة",
      "type": "object",
      "properties": {
        "paymentId": { "type": "string" },
        "userId": { "type": "string", "description": "مرجع المستخدم صاحب العملية" },
        "storeId": { "type": "string", "description": "مرجع المتجر المرتبط (إن وجد)" },
        "amount": { "type": "number", "description": "المبلغ بالدينار الجزائري" },
        "paymentMethod": { "type": "string", "description": "وسيلة الدفع (CCP, Baridimob, CIB, etc.)" },
        "paymentDate": { "type": "string", "format": "date-time" },
        "receiptImage": { "type": "string", "description": "رابط صورة وصل الدفع المرفوع" },
        "status": { 
          "type": "string", 
          "enum": ["Pending", "Approved", "Rejected", "Refunded"],
          "description": "حالة العملية المالية"
        },
        "approvedBy": { "type": "string", "description": "معرف المسؤول الذي قام بمراجعة العملية" },
        "approvalDate": { "type": "string", "format": "date-time" },
        "notes": { "type": "string", "description": "ملاحظات إضافية حول العملية" }
      },
      "required": ["userId", "amount", "paymentMethod", "status"]
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "/listings/{listingId}": {
      "schema": "Listing",
      "description": "مجموعة الإعلانات العامة"
    },
    "/sellers/{sellerId}": {
      "schema": "Seller",
      "description": "بيانات البائعين"
    },
    "/buyers/{buyerId}": {
      "schema": "Buyer",
      "description": "بيانات المشترين"
    },
    "/payments/{paymentId}": {
      "schema": "Payment",
      "description": "سجل عمليات الدفع والتحويلات المالية في المنصة"
    }
  }
}

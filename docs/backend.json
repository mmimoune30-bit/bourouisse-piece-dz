
{
  "entities": {
    "User": {
      "title": "ملف المستخدم",
      "description": "بيانات حساب المستخدم وصلاحياته في النظام",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "معرف المستخدم الفريد من Firebase Auth" },
        "name": { "type": "string", "description": "الاسم الكامل" },
        "email": { "type": "string", "format": "email", "description": "البريد الإلكتروني" },
        "role": { 
          "type": "string", 
          "enum": ["Super Admin", "Manager", "Financial Officer", "Customer Service", "Seller", "Customer"],
          "description": "الدور الوظيفي للمستخدم" 
        },
        "status": { "type": "string", "enum": ["Active", "Blocked"], "description": "حالة الحساب" },
        "storeId": { "type": "string", "description": "معرف المتجر (خاص بالبائعين فقط)" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "role", "status"]
    },
    "Listing": {
      "title": "إعلان قطعة غيار",
      "description": "بيانات تفصيلية لقطعة غيار معروضة للبيع",
      "type": "object",
      "properties": {
        "vehicleType": { "type": "string" },
        "brand": { "type": "string" },
        "model": { "type": "string" },
        "year": { "type": "string" },
        "category": { "type": "string" },
        "partName": { "type": "string" },
        "price": { "type": "number" },
        "sellerId": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Sold"] }
      }
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "سجلات المستخدمين والصلاحيات"
    },
    "/listings/{listingId}": {
      "schema": "Listing",
      "description": "مجموعة الإعلانات وقطع الغيار"
    }
  }
}

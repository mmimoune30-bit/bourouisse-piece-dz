
{
  "entities": {
    "User": {
      "title": "ملف المستخدم",
      "description": "بيانات حساب المستخدم وصلاحياته في النظام",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { 
          "type": "string", 
          "enum": ["Super Admin", "Manager", "Financial Officer", "Customer Service", "Seller", "Customer"]
        },
        "status": { "type": "string", "enum": ["Active", "Blocked"] },
        "subscription": {
          "type": "object",
          "properties": {
            "plan": { "type": "string" },
            "startDate": { "type": "string", "format": "date-time" },
            "endDate": { "type": "string", "format": "date-time" },
            "status": { "type": "string" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "SubscriptionRequest": {
      "title": "طلب اشتراك",
      "description": "طلب تفعيل أو تجديد باقة من قبل البائع",
      "type": "object",
      "properties": {
        "sellerId": { "type": "string" },
        "sellerName": { "type": "string" },
        "planId": { "type": "string" },
        "type": { "type": "string", "enum": ["New", "Renew", "Upgrade"] },
        "paymentMethod": { "type": "string" },
        "receiptUrl": { "type": "string" },
        "refNumber": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Approved", "Rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Notification": {
      "title": "إشعار",
      "description": "تنبيهات النظام للمستخدمين",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "سجلات المستخدمين" },
    "/subscription_requests/{requestId}": { "schema": "SubscriptionRequest", "description": "طلبات الدفع والتنشيط" },
    "/notifications/{notificationId}": { "schema": "Notification", "description": "إشعارات النظام" }
  }
}

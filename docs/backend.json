
{
  "entities": {
    "Listing": {
      "title": "إعلان قطعة غيار أو مركبة",
      "description": "بيانات تفصيلية لقطعة غيار أو مركبة معروضة للبيع",
      "type": "object",
      "properties": {
        "vehicleType": { "type": "string", "description": "نوع المركبة: سياحية، نفعية، شاحنة..." },
        "brand": { "type": "string", "description": "العلامة التجارية للمركبة" },
        "model": { "type": "string", "description": "موديل المركبة" },
        "year": { "type": "string", "description": "سنة الصنع" },
        "category": { "type": "string", "description": "فئة القطعة: محرك، هيكل، إضاءة..." },
        "partName": { "type": "string", "description": "اسم القطعة" },
        "partNumber": { "type": "string", "description": "رقم القطعة الأصلي" },
        "condition": { "type": "string", "enum": ["new", "used"], "description": "حالة القطعة" },
        "price": { "type": "number", "description": "السعر بالدينار الجزائري" },
        "quantity": { "type": "number", "description": "الكمية المتوفرة" },
        "description": { "type": "string", "description": "وصف إضافي" },
        "images": { "type": "array", "items": { "type": "string" }, "description": "روابط صور القطعة" },
        "wilaya": { "type": "string", "description": "ولاية البائع" },
        "commune": { "type": "string", "description": "بلدية البائع" },
        "sellerId": { "type": "string", "description": "معرف البائع صاحب الإعلان" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["vehicleType", "brand", "model", "year", "category", "partName", "price"]
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "/listings/{listingId}": {
      "schema": "Listing",
      "description": "مجموعة الإعلانات وقطع الغيار"
    }
  }
}
